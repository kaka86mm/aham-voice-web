# Aham Voice Web 配置。复制为 .env 后按需修改。
# Docker 部署：docker-compose.yml 的 env_file 指向此文件。
# 本地开发：直接设环境变量，或用 .env（python-dotenv 自动读）。

# --- 服务绑定 ---
AHAMVOICE_HOST=0.0.0.0
AHAMVOICE_PORT=8765

# --- 访问密码门（空=不启用裸奔；非空=启用单密码门，浏览器访问先输密码）---
AHAMVOICE_ACCESS_PASSWORD=

# --- 数据/模型目录 ---
# 容器内固定路径（配合 docker-compose volume 挂载）
AHAMVOICE_HOME=/data
AHAMVOICE_MODELS_DIR=/models
# 本地开发可改为本地路径（如 RECORDING_AI_HOME=~/.cache/recording-ai）

# --- 大模型（OpenAI 兼容端点；纪要/情绪用）---
# 支持任何 OpenAI Chat Completions 兼容的端点：DeepSeek / 通义 / Kimi /
# 本地 Ollama(v1) / vLLM / OpenAI 本尊等。默认 DeepSeek 开箱即用，换别的改这里或设置页。
# 新名 LLM_*；旧名 DEEPSEEK_* 仍可读（向后兼容）。
LLM_API_KEY=
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# --- ASR 性能 ---
# 容器内只能 cpu 或 cuda（无 mps；mps 需原生 macOS）
# :latest 镜像用 cpu；:gpu 镜像用 cuda
AHAMVOICE_ASR_DEVICE=cpu
AHAMVOICE_ASR_THREADS=
AHAMVOICE_BATCH_SIZE_S=300

# --- 可选调优（保留原项目全部开关）---
# AHAMVOICE_UPLOAD_MAX_MB=2048
# AHAMVOICE_TMP_TTL_HOURS=24
# AHAMVOICE_EXPORT_TTL_DAYS=14
# AHAMVOICE_SWEEP_INTERVAL_MINUTES=60
# AHAMVOICE_HOTWORD_LIMIT=3000
# AHAMVOICE_VOICEPRINT_THRESHOLD=0.66
